{
  "name": "@browserless.io/browserless",
  "version": "2.42.0",
  "license": "SSPL",
  "description": "The browserless platform",
  "author": "browserless.io",
  "type": "module",
  "types": "./src/exports.ts",
  "main": "./build/exports.js",
  "exports": {
    ".": "./build/exports.js"
  },
  "bin": {
    "browserless": "./bin/browserless.js"
  },
  "scripts": {
    "build": "npm run clean && npm run build:ts && npm run install:adblock && npm run build:schemas && npm run build:devtools && npm run build:openapi",
    "build:dev": "npm run build && npm run build:function && npm run install:debugger",
    "build:devtools": "node scripts/install-devtools.js",
    "build:function": "node scripts/build-function.js",
    "build:schemas": "node scripts/build-schemas.js",
    "build:openapi": "node scripts/build-open-api.js",
    "build:ts": "tsc",
    "build:tests": "npm run build:ts && npm run build:function && npm run install:debugger",
    "clean": "node scripts/clean.js",
    "dev": "npm run build:dev && env-cmd -f .env node build",
    "install:adblock": "node scripts/install-adblock.js",
    "install:debugger": "node scripts/install-debugger.js",
    "install:browsers": "node node_modules/playwright-core/cli.js install chromium firefox webkit msedge",
    "install:dev": "npm run install:browsers && npm run install:debugger",
    "lint": "cross-env eslint . --fix",
    "prepack": "npm run build:dev",
    "prettier": "prettier '{src,functions,scripts,bin,external,.github}/**/*.{js,ts,json,yml,yaml,md}' --log-level error --write",
    "test": "npm run build:tests && cross-env DEBUG=quiet mocha",
    "coverage": "npm run build:ts && c8 --reporter=text --reporter=html --reporter=lcov cross-env DEBUG=quiet mocha",
    "start": "env-cmd -f .env node build"
  },
  "files": [
    "assets/*",
    "bin/*",
    "build/*",
    "docker/*",
    "extensions/*",
    "external/*",
    "fonts/*",
    "scripts/*",
    "src/*",
    "static/*",
    "CHANGELOG.md",
    "tsconfig.json"
  ],
  "dependencies": {
    "@hapi/bourne": "^3.0.0",
    "@hapi/hoek": "^11.0.4",
    "debug": "^4.4.1",
    "del": "^8.0.1",
    "file-type": "^21.3.0",
    "get-port": "^7.1.0",
    "gradient-string": "^3.0.0",
    "http-proxy": "^1.18.1",
    "joi": "^18.0.2",
    "lighthouse": "^13.0.3",
    "micromatch": "^4.0.8",
    "playwright-1.54": "npm:playwright-core@1.54.2",
    "playwright-1.55": "npm:playwright-core@1.55.1",
    "playwright-1.56": "npm:playwright-core@1.56.1",
    "playwright-1.57": "npm:playwright-core@1.57.0",
    "playwright-core": "1.58.2",
    "puppeteer-core": "24.37.5",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "queue": "^7.0.0",
    "systeminformation": "^5.31.1",
    "tar-fs": "^3.1.1"
  },
  "optionalDependencies": {
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.12",
    "@types/gradient-string": "^1.1.6",
    "@types/http-proxy": "^1.17.17",
    "@types/micromatch": "^4.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "@types/sinon": "^21.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "assert": "^2.0.0",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "env-cmd": "^11.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "eslint": "^10.0.2",
    "extract-zip": "^2.0.1",
    "gunzip-maybe": "^1.4.2",
    "marked": "^17.0.3",
    "mocha": "^11.7.5",
    "move-file": "^4.1.0",
    "prettier": "^3.8.1",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.65.1"
  },
  "playwrightVersions": {
    "default": "playwright-core",
    "1.58": "playwright-core",
    "1.57": "playwright-1.57",
    "1.56": "playwright-1.56",
    "1.55": "playwright-1.55",
    "1.54": "playwright-1.54"
  },
  "engines": {
    "node": ">=24",
    "npm": "^11.7.0"
  },
  "mocha": {
    "extension": [
      "js"
    ],
    "loader": "ts-node/esm",
    "spec": "build/**/*.spec.js",
    "timeout": 45000,
    "slow": 5000
  },
  "prettier": {
    "semi": true,
    "trailingComma": "all",
    "singleQuote": true,
    "printWidth": 80
  }
}
